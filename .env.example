# 이 파일을 .env로 복사한 뒤 값을 채운다: cp .env.example .env
# .env는 .gitignore에 포함되어 커밋되지 않는다.

# PostgreSQL (백엔드 스토어: 실험/메타데이터/프롬프트)
POSTGRES_USER=mlflow
POSTGRES_PASSWORD=mlflow
POSTGRES_DB=mlflow

# MinIO (아티팩트 스토어, S3 호환)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MLFLOW_BUCKET=mlflow

# basic-auth CSRF 보호용 정적 시크릿 키 (운영 시 임의의 강한 값으로 교체)
MLFLOW_FLASK_SERVER_SECRET_KEY=dev-only-change-me-to-a-random-secret
